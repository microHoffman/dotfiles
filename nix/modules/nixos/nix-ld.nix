{ pkgs, ... }:
{
  programs.nix-ld = {
    enable = true;
    libraries = with pkgs; [
      alsa-lib
      at-spi2-atk
      bzip2
      cairo
      curl
      cups
      dbus
      expat
      fontconfig
      freetype
      gdk-pixbuf
      glib
      gtk3
      libGL
      libffi
      libgbm
      libxkbcommon
      libxcrypt
      libxml2
      ncurses
      nspr
      nss
      openssl
      pango
      readline
      sqlite
      stdenv.cc.cc
      systemd
      util-linux
      libx11
      libxcomposite
      libxcursor
      libxdamage
      libxext
      libxfixes
      libxi
      libxrandr
      libxrender
      libxtst
      libxcb
      libxkbfile
      xz
      zlib
      zstd
    ];
  };
}
